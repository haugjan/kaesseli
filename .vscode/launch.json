{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Kaesseli: Dev",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Kaesseli/bin/Debug/net10.0/Kaesseli.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Kaesseli",
            "stopAtEntry": false,
            "launchSettingsProfile": "Dev",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Kaesseli: Prod",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Kaesseli/bin/Debug/net10.0/Kaesseli.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Kaesseli",
            "stopAtEntry": false,
            "launchSettingsProfile": "Prod",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        }
    ]
}
