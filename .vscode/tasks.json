{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Kaesseli.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "start-aspire-dashboard",
            "type": "shell",
            "command": "docker compose -f ${workspaceFolder}/Kaesseli.Deploy/docker-compose.yml up -d aspire-dashboard",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "open-aspire-dashboard",
            "type": "shell",
            "command": "start http://localhost:18888",
            "problemMatcher": [],
            "dependsOn": "start-aspire-dashboard",
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}
