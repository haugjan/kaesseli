@page "/settings/periods/{PeriodId:guid}"
@using Kaesseli.Client.Blazor.Services
@inject KaesseliApiService Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_period?.Description ?? "Periode")</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-4" />

@if (_loading)
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="mb-4" />
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
}
else if (_period is null)
{
    <MudAlert Severity="Severity.Error">Periode nicht gefunden.</MudAlert>
}
else
{
    @* === Budget Section (Revenue + Expense) === *@
    <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
        <MudCardHeader>
            <CardHeaderAvatar>
                <MudAvatar Style="background-color: #795548; color: white;" Size="Size.Medium">
                    <MudIcon Icon="@Icons.Material.Rounded.Savings" />
                </MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Budget (Einkommen / Ausgaben)</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Class="pa-0">
            <MudTable Items="_budgetRows" Dense="true" Hover="true" Elevation="0" Style="background: transparent;">
                <HeaderContent>
                    <MudTh>Konto</MudTh>
                    <MudTh>Typ</MudTh>
                    <MudTh Style="text-align: right;">Budget (p.J.)</MudTh>
                    <MudTh>Beschreibung</MudTh>
                    <MudTh Style="text-align: right; min-width: 200px;">Neuer Betrag</MudTh>
                    <MudTh Style="min-width: 220px;">Neue Beschreibung</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Konto">@context.AccountName</MudTd>
                    <MudTd DataLabel="Typ">@context.AccountType</MudTd>
                    <MudTd DataLabel="Budget" Style="text-align: right; font-weight: 700;">
                        @(context.CurrentAmount.HasValue ? context.CurrentAmount.Value.ToString("N2") : "—")
                    </MudTd>
                    <MudTd DataLabel="Beschreibung">@(context.CurrentDescription ?? "—")</MudTd>
                    <MudTd>
                        <MudNumericField @bind-Value="context.NewAmount" Margin="Margin.Dense" Variant="Variant.Outlined"
                                         Format="N2" HideSpinButtons="true" Style="max-width: 160px;" />
                    </MudTd>
                    <MudTd>
                        <MudTextField @bind-Value="context.NewDescription" Margin="Margin.Dense" Variant="Variant.Outlined"
                                      Style="max-width: 200px;" />
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Rounded.Save" Color="Color.Primary" Size="Size.Small"
                                       Disabled="@(!context.HasChanges)"
                                       OnClick="() => SaveBudget(context)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCardContent>
    </MudCard>

    @* === Opening Balance Section (Asset accounts) === *@
    <MudCard Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
        <MudCardHeader>
            <CardHeaderAvatar>
                <MudAvatar Style="background-color: #1E88E5; color: white;" Size="Size.Medium">
                    <MudIcon Icon="@Icons.Material.Rounded.AccountBalanceWallet" />
                </MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Eröffnungssaldos (Aktivkonten)</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Class="pa-0">
            <MudTable Items="_openingBalanceRows" Dense="true" Hover="true" Elevation="0" Style="background: transparent;">
                <HeaderContent>
                    <MudTh>Aktivkonto</MudTh>
                    <MudTh Style="text-align: right;">Aktueller Saldo</MudTh>
                    <MudTh>Gegenkonto (Passiv)</MudTh>
                    <MudTh Style="text-align: right; min-width: 200px;">Betrag</MudTh>
                    <MudTh Style="min-width: 220px;">Beschreibung</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Aktivkonto">@context.AccountName</MudTd>
                    <MudTd DataLabel="Saldo" Style="text-align: right; font-weight: 700;">
                        @(context.CurrentAmount.HasValue ? context.CurrentAmount.Value.ToString("N2") : "—")
                    </MudTd>
                    <MudTd>
                        <MudSelect T="Guid?" @bind-Value="context.SelectedLiabilityAccountId" Margin="Margin.Dense"
                                   Variant="Variant.Outlined" Placeholder="Gegenkonto wählen" Style="max-width: 200px;">
                            @foreach (var la in _liabilityAccounts)
                            {
                                <MudSelectItem T="Guid?" Value="la.Id">@la.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudNumericField @bind-Value="context.NewAmount" Margin="Margin.Dense" Variant="Variant.Outlined"
                                         Format="N2" HideSpinButtons="true" Style="max-width: 160px;" />
                    </MudTd>
                    <MudTd>
                        <MudTextField @bind-Value="context.NewDescription" Margin="Margin.Dense" Variant="Variant.Outlined"
                                      Placeholder="Eröffnungssaldo" Style="max-width: 200px;" />
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Rounded.Add" Color="Color.Primary" Size="Size.Small"
                                       Disabled="@(!context.CanSave)"
                                       OnClick="() => SaveOpeningBalance(context)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter] public Guid PeriodId { get; set; }

    private AccountingPeriod? _period;
    private bool _loading = true;
    private List<BudgetRow> _budgetRows = [];
    private List<OpeningBalanceRow> _openingBalanceRows = [];
    private List<Contracts.Accounts.Account> _liabilityAccounts = [];

    private List<BreadcrumbItem> _breadcrumbs =>
    [
        new("Buchungsperioden", "/settings/periods", icon: Icons.Material.Rounded.CalendarMonth),
        new(_period?.Description ?? "...", null, disabled: true),
    ];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;

        var periodsTask = Api.GetAccountingPeriodsAsync();
        var accountsTask = Api.GetAccountsAsync();
        var budgetTask = Api.GetBudgetEntriesAsync(PeriodId);
        var journalTask = Api.GetJournalEntriesAsync(PeriodId);

        await Task.WhenAll(periodsTask, accountsTask, budgetTask, journalTask);

        var periods = (await periodsTask)?.ToList() ?? [];
        _period = periods.FirstOrDefault(p => p.Id == PeriodId);

        var accounts = (await accountsTask)?.ToList() ?? [];
        var budgets = (await budgetTask)?.ToList() ?? [];
        var journalEntries = (await journalTask)?.ToList() ?? [];

        _liabilityAccounts = accounts.Where(a => a.TypeId == AccountType.Liability).OrderBy(a => a.Name).ToList();

        // Budget rows: Revenue + Expense accounts
        _budgetRows = accounts
            .Where(a => a.TypeId is AccountType.Revenue or AccountType.Expense)
            .OrderBy(a => a.TypeId).ThenBy(a => a.Name)
            .Select(a =>
            {
                var budget = budgets.FirstOrDefault(b => b.AccountId == a.Id);
                return new BudgetRow
                {
                    AccountId = a.Id,
                    AccountName = a.Name,
                    AccountType = FormatAccountType(a.TypeId),
                    CurrentAmount = budget?.Amount,
                    CurrentDescription = budget?.Description,
                    NewAmount = budget?.Amount,
                    NewDescription = budget?.Description ?? a.Name,
                };
            }).ToList();

        // Opening balance rows: Asset accounts
        var openingBalances = journalEntries.Where(j => j.IsOpeningBalance).ToList();
        _openingBalanceRows = accounts
            .Where(a => a.TypeId == AccountType.Asset)
            .OrderBy(a => a.Name)
            .Select(a =>
            {
                var ob = openingBalances.FirstOrDefault(j => j.DebitAccountId == a.Id);
                return new OpeningBalanceRow
                {
                    AccountId = a.Id,
                    AccountName = a.Name,
                    CurrentAmount = ob?.Amount,
                    NewDescription = "Eröffnungssaldo",
                };
            }).ToList();

        _loading = false;
    }

    private async Task SaveBudget(BudgetRow row)
    {
        if (row.NewAmount is null) return;
        try
        {
            await Api.SetBudgetAsync(row.NewAmount.Value, row.NewDescription ?? row.AccountName, row.AccountId, PeriodId);
            Snackbar.Add($"Budget für {row.AccountName} gespeichert.", Severity.Success);
            await LoadAsync();
        }
        catch
        {
            Snackbar.Add("Fehler beim Speichern.", Severity.Error);
        }
    }

    private async Task SaveOpeningBalance(OpeningBalanceRow row)
    {
        if (row.NewAmount is null || row.SelectedLiabilityAccountId is null) return;
        try
        {
            await Api.AddOpeningBalanceAsync(
                row.NewAmount.Value,
                row.NewDescription ?? "Eröffnungssaldo",
                row.AccountId,
                row.SelectedLiabilityAccountId.Value,
                PeriodId);
            Snackbar.Add($"Eröffnungssaldo für {row.AccountName} erstellt.", Severity.Success);
            await LoadAsync();
        }
        catch
        {
            Snackbar.Add("Fehler beim Speichern.", Severity.Error);
        }
    }

    private class BudgetRow
    {
        public Guid AccountId { get; init; }
        public string AccountName { get; init; } = "";
        public string AccountType { get; init; } = "";
        public decimal? CurrentAmount { get; set; }
        public string? CurrentDescription { get; set; }
        public decimal? NewAmount { get; set; }
        public string? NewDescription { get; set; }
        public bool HasChanges => NewAmount.HasValue && (NewAmount != CurrentAmount || NewDescription != CurrentDescription);
    }

    private class OpeningBalanceRow
    {
        public Guid AccountId { get; init; }
        public string AccountName { get; init; } = "";
        public decimal? CurrentAmount { get; set; }
        public Guid? SelectedLiabilityAccountId { get; set; }
        public decimal? NewAmount { get; set; }
        public string? NewDescription { get; set; }
        public bool CanSave => NewAmount.HasValue && SelectedLiabilityAccountId.HasValue;
    }

    private static string FormatAccountType(AccountType type) => type switch
    {
        AccountType.Asset => "Aktiv",
        AccountType.Liability => "Passiv",
        AccountType.Revenue => "Einkommen",
        AccountType.Expense => "Ausgaben",
        _ => type.ToString()
    };
}
