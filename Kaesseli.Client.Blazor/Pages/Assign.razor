@page "/assign"
@using Kaesseli.Client.Blazor.Services
@inject KaesseliApiService Api
@inject AccountingPeriodState PeriodState
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Zuweisen</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-4" />

<div class="d-flex align-center gap-3 mb-4">
    <MudButton StartIcon="@Icons.Material.Rounded.AutoAwesome"
               Color="Color.Secondary"
               Variant="Variant.Outlined"
               Disabled="@(_jobStatus?.IsRunning == true)"
               OnClick="OnGenerateSuggestionsClick">
        @(_jobStatus?.IsRunning == true ? "KI-Vorschläge laufen…" : "KI-Vorschläge generieren")
    </MudButton>
    @if (_jobStatus is not null && (_jobStatus.IsRunning || _jobStatus.Processed > 0 || _jobStatus.Failed > 0))
    {
        <MudText Typo="Typo.body2">
            @_jobStatus.Processed / @_jobStatus.Total verarbeitet
            @if (_jobStatus.Failed > 0)
            {
                <span> · @_jobStatus.Failed Fehler</span>
            }
        </MudText>
        @if (_jobStatus.IsRunning)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        }
    }
</div>

@if (_transaction is not null)
{
    <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
        <MudCardContent>
            <div class="d-flex align-center">
                <MudText Typo="Typo.h6">
                    @_transaction.ValueDate.ToString("dddd, dd. MMMM yyyy")
                </MudText>
                <MudSpacer />
                <MudTooltip Text="Ignorieren / überspringen">
                    <MudIconButton Icon="@Icons.Material.Rounded.VisibilityOff"
                                   Color="Color.Default"
                                   OnClick="OnIgnoreClick" />
                </MudTooltip>
            </div>
            <MudChip T="string"
                     Style="@(_transaction.Amount >= 0 ? "background-color: #21BA45; color: white;" : "background-color: #C10015; color: white;")"
                     Icon="@(_transaction.Amount >= 0 ? Icons.Material.Rounded.AttachMoney : Icons.Material.Rounded.MoneyOff)">
                @_transaction.Amount.ToString("N2")
            </MudChip>
            <MudText Typo="Typo.subtitle1" Class="mt-2">@_transaction.AccountName</MudText>
            <MudDivider Class="my-2" />
            <MudText>@_transaction.Description</MudText>
        </MudCardContent>
    </MudCard>

    <MudExpansionPanels Class="mb-4" Elevation="0">
        <MudExpansionPanel @bind-Expanded="_isAutomationActive" Text="Automatisieren"
                           Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
            <div class="d-flex align-end gap-4">
                <MudTextField T="string" @bind-Value="_automateInput" Label="Automatisieren"
                              Immediate="true" TextChanged="OnAutomationInputChanged"
                              Style="max-width: 500px;" />
                <MudChip T="string" Color="Color.Error">@_nrOfPossibleAutomations Treffer</MudChip>
            </div>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudTextField T="string" @bind-Value="_filterText" Label="Filter" Variant="Variant.Filled"
                  Immediate="true" Class="mb-4" Style="max-width: 400px;"
                  @ref="_filterInput" @onkeydown="OnFilterKeyDown"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search" />

    @if (_splittingAccounts.Count > 0)
    {
        <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; background-color: var(--mud-palette-background-grey);">
            <MudCardContent>
                <MudGrid>
                    @foreach (var split in _splittingAccounts)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <div class="d-flex align-center gap-2">
                                <MudChip T="string" Style="@($"background-color: {split.Account.AccountIconColor}; color: white;")"
                                         Icon="@GetMudIcon(split.Account.AccountIcon)">
                                    @split.Account.AccountName
                                </MudChip>
                                <MudNumericField T="decimal" @bind-Value="split.Amount" Label="Betrag"
                                                 Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 TextChanged="@(() => OnSplitAmountChanged(split))" />
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            </MudCardContent>
            <MudCardActions>
                <MudButton Color="Color.Primary" OnClick="OnAssignMultipleClick">Betrag aufteilen</MudButton>
            </MudCardActions>
        </MudCard>
    }

    @if (TopAiSuggestions.Count > 0)
    {
        <MudText Typo="Typo.subtitle2" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" Size="Size.Small" />
            KI-Vorschläge
        </MudText>
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var item in TopAiSuggestions)
            {
                var acc = item.Account;
                var conf = item.Confidence;
                <div @onclick="@(async e => await OnAccountClick(acc, e))" @onclick:stopPropagation style="cursor: pointer;">
                    <MudChip T="string"
                             Style="@($"background-color: {acc.AccountIconColor}; color: white; border: 2px solid var(--mud-palette-primary);")"
                             Icon="@GetMudIcon(acc.AccountIcon)">
                        @acc.AccountName · @($"{conf * 100:N0}%")
                    </MudChip>
                </div>
            }
        </div>
        <MudDivider Class="mb-3" />
    }

    <div class="d-flex flex-wrap gap-2">
        @foreach (var account in FilteredAccounts)
        {
            var acc = account;
            <div @onclick="@(async e => await OnAccountClick(acc, e))" @onclick:stopPropagation style="cursor: pointer;">
                <MudChip T="string" Style="@($"background-color: {acc.AccountIconColor}; color: white;")"
                         Icon="@GetMudIcon(acc.AccountIcon)">
                    @acc.AccountName
                </MudChip>
            </div>
        }
    </div>
}
else
{
    <MudAlert Severity="Severity.Info">Keine offenen Transaktionen vorhanden.</MudAlert>
}

@code {
    private OpenTransaction? _transaction;
    private string _filterText = "";
    private readonly List<SplitAccount> _splittingAccounts = [];
    private string _automateInput = "";
    private int _nrOfPossibleAutomations;
    private bool _isAutomationActive;
    private MudTextField<string>? _filterInput;
    private AccountSuggestionJobStatus? _jobStatus;
    private CancellationTokenSource? _pollCts;

    private List<TopSuggestion> TopAiSuggestions
    {
        get
        {
            if (_transaction is null || _transaction.AiSuggestions is null) return [];
            var splittingIds = _splittingAccounts.Select(s => s.Account.AccountId).ToHashSet();
            var byId = _transaction.SuggestedAccounts.ToDictionary(a => a.AccountId);
            return _transaction.AiSuggestions
                .Where(s => byId.ContainsKey(s.AccountId))
                .Where(s => s.AccountId != _transaction.AccountId)
                .Where(s => !splittingIds.Contains(s.AccountId))
                .OrderBy(s => s.Rank)
                .Select(s => new TopSuggestion(byId[s.AccountId], s.Confidence))
                .ToList();
        }
    }

    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Zuweisen", "/assign", icon: Icons.Material.Rounded.AssignmentTurnedIn)
    ];

    private IEnumerable<SuggestedAccount> FilteredAccounts
    {
        get
        {
            if (_transaction is null) return [];

            var splittingIds = _splittingAccounts.Select(s => s.Account.AccountId).ToHashSet();
            var searchWords = _filterText.ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);

            return _transaction.SuggestedAccounts
                .Where(a => a.AccountId != _transaction.AccountId)
                .Where(a => !splittingIds.Contains(a.AccountId))
                .Where(a => searchWords.Length == 0 || searchWords.All(word =>
                    a.AccountName.ToLower().Split(' ').Any(w => w.StartsWith(word))));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PeriodState.OnChange += OnPeriodChanged;
        await LoadAsync();
        await RefreshJobStatusAsync();
        if (_jobStatus?.IsRunning == true) StartPolling();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _filterInput is not null)
            await _filterInput.FocusAsync();
    }

    private void OnPeriodChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    private async Task LoadAsync()
    {
        _transaction = await Api.GetNextOpenTransactionAsync();
        _automateInput = _transaction?.Description ?? "";
        _filterText = "";
        _splittingAccounts.Clear();
        // Automatisierung bewusst pro Transaktion neu aktivieren lassen, damit nicht
        // versehentlich für den Folgebetrag ebenfalls eine Automatisierung entsteht.
        _isAutomationActive = false;
    }

    private async Task OnAccountClick(SuggestedAccount account, MouseEventArgs e)
    {
        if (e.CtrlKey)
        {
            AddToSplitList(account);
        }
        else
        {
            await AssignSingleAccount(account);
        }
    }

    private void AddToSplitList(SuggestedAccount account)
    {
        if (_transaction is null) return;

        _splittingAccounts.Add(new SplitAccount(account, 0));
        RecalculateSplitAmounts();
    }

    private void RecalculateSplitAmounts()
    {
        if (_transaction is null || _splittingAccounts.Count == 0) return;

        var equalShare = Math.Round(_transaction.Amount / _splittingAccounts.Count, 2);
        decimal sum = 0;
        for (var i = 0; i < _splittingAccounts.Count; i++)
        {
            _splittingAccounts[i].Amount = equalShare;
            sum += equalShare;
        }
        _splittingAccounts[^1].Amount += _transaction.Amount - sum;
    }

    private async Task AssignSingleAccount(SuggestedAccount account)
    {
        if (_transaction is null || PeriodState.SelectedPeriodId is null) return;

        try
        {
            await Api.AssignTransactionAsync(
                PeriodState.SelectedPeriodId.Value,
                _transaction.Id,
                account.AccountId);

            if (_isAutomationActive)
            {
                await Api.AddAutomationAsync(
                    _automateInput,
                    PeriodState.SelectedPeriodId.Value,
                    [new KaesseliApiService.AutomationSplitEntry(account.AccountShortName, _transaction.Amount)]);
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnAssignMultipleClick()
    {
        if (_transaction is null || PeriodState.SelectedPeriodId is null) return;

        try
        {
            var entries = _splittingAccounts
                .Select(s => new KaesseliApiService.SplitEntry(s.Account.AccountId, s.Amount))
                .ToList();

            await Api.SplitTransactionAsync(
                PeriodState.SelectedPeriodId.Value,
                _transaction.Id,
                entries);

            if (_isAutomationActive)
            {
                var automationEntries = _splittingAccounts
                    .Select(s => new KaesseliApiService.AutomationSplitEntry(s.Account.AccountShortName, s.Amount))
                    .ToList();

                await Api.AddAutomationAsync(
                    _automateInput,
                    PeriodState.SelectedPeriodId.Value,
                    automationEntries);
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private void OnSplitAmountChanged(SplitAccount changed)
    {
        if (_transaction is null || _splittingAccounts.Count != 2) return;

        var other = _splittingAccounts.First(s => s != changed);
        other.Amount = Math.Round(_transaction.Amount - changed.Amount, 2);
    }

    private async Task OnAutomationInputChanged(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return;
        _nrOfPossibleAutomations = await Api.GetNrOfPossibleAutomationsAsync(text);
    }

    private async Task OnIgnoreClick()
    {
        if (_transaction is null) return;

        try
        {
            await Api.SetTransactionIgnoredAsync(_transaction.Id, isIgnored: true);
            Snackbar.Add("Transaktion ignoriert.", Severity.Info);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnFilterKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            var filtered = FilteredAccounts.ToList();
            if (filtered.Count == 1)
                await OnAccountClick(filtered[0], new MouseEventArgs { CtrlKey = e.CtrlKey });
        }
    }

    private async Task OnGenerateSuggestionsClick()
    {
        try
        {
            _jobStatus = await Api.StartAccountSuggestionJobAsync();
            if (_jobStatus is { Started: false, IsRunning: true })
                Snackbar.Add("Es läuft bereits ein KI-Job.", Severity.Info);
            StartPolling();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"KI-Job konnte nicht gestartet werden: {ex.Message}", Severity.Error);
        }
    }

    private async Task RefreshJobStatusAsync()
    {
        try
        {
            _jobStatus = await Api.GetAccountSuggestionJobStatusAsync();
        }
        catch
        {
            // Status-Polling-Fehler dürfen die UI nicht stoppen.
        }
    }

    private void StartPolling()
    {
        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;
        _ = Task.Run(async () =>
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(2000, ct);
                await InvokeAsync(async () =>
                {
                    var previousProcessed = _jobStatus?.Processed ?? 0;
                    await RefreshJobStatusAsync();
                    StateHasChanged();
                    if (_jobStatus is { IsRunning: false })
                    {
                        _pollCts?.Cancel();
                        // Reload current transaction so a fresh suggestion shows up.
                        if (_jobStatus.Processed > previousProcessed)
                            await LoadAsync();
                        StateHasChanged();
                    }
                });
            }
        }, ct);
    }

    public void Dispose()
    {
        PeriodState.OnChange -= OnPeriodChanged;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }

    private record TopSuggestion(SuggestedAccount Account, double Confidence);

    private static string GetMudIcon(string iconName) => iconName switch
    {
        _ => Components.AccountDialog.ResolveIcon(iconName),
    };

    private class SplitAccount(SuggestedAccount account, decimal amount)
    {
        public SuggestedAccount Account { get; } = account;
        public decimal Amount { get; set; } = amount;
    }
}
