@page "/import"
@using Kaesseli.Client.Blazor.Components
@using Kaesseli.Client.Blazor.Services
@inject KaesseliApiService Api
@inject AccountingPeriodState PeriodState
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Import</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-4" />

<MudCard Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; max-width: 600px;">
    <MudCardContent>
        <MudFileUpload T="IBrowserFile" @bind-Files="_file" Accept=".camt,.xml,.csv,.zip">
            <CustomContent Context="fileUpload">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@fileUpload.OpenFilePickerAsync"
                           StartIcon="@Icons.Material.Rounded.CloudUpload">
                    Datei auswählen
                </MudButton>
            </CustomContent>
        </MudFileUpload>

        @if (_file is not null)
        {
            <MudChip T="string" Class="mt-2" Icon="@Icons.Material.Rounded.InsertDriveFile"
                     OnClose="@(() => _file = null)">
                @_file.Name (@(_file.Size / 1024) KB)
            </MudChip>
        }

        <MudSelect T="Guid?" @bind-Value="_selectedAccountId" Label="Konto auswählen"
                   Variant="Variant.Filled" Class="mt-4"
                   AnchorOrigin="Origin.BottomLeft">
            @if (_accounts is not null)
            {
                @foreach (var account in _accounts)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)account.Id)">@account.Name</MudSelectItem>
                }
            }
        </MudSelect>

        @if (_balanceCheck is not null)
        {
            <MudAlert Severity="@BalanceSeverity" Class="mt-3" Dense="true" ShowCloseIcon="true"
                      CloseIconClicked="@(() => _balanceCheck = null)">
                @if (_balanceCheck.LatestStatementDate is null)
                {
                    <text>Für dieses Konto wurde noch kein CAMT-Statement importiert.</text>
                }
                else
                {
                    <div>
                        <b>Letztes CAMT (@_balanceCheck.LatestStatementDate.Value.ToString("dd.MM.yyyy")):</b>
                        @_balanceCheck.LatestStatementBalance!.Value.ToString("N2") CHF
                    </div>
                    <div>
                        <b>Aktueller Kontostand (Periode):</b>
                        @_balanceCheck.CurrentBalance.ToString("N2") CHF
                    </div>
                    <div>
                        <b>Differenz:</b> @_balanceCheck.Difference!.Value.ToString("N2") CHF
                        @if (_balanceCheck.Difference == 0m)
                        {
                            <span> – stimmt überein.</span>
                        }
                        else
                        {
                            <span> – noch offene Transaktionen oder fehlende Buchungen.</span>
                        }
                    </div>
                }
            </MudAlert>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Color="Color.Default" Variant="Variant.Outlined"
                   Disabled="@(_selectedAccountId is null || PeriodState.SelectedPeriodId is null || _checking)"
                   OnClick="OnCheckBalance"
                   StartIcon="@(_checking ? Icons.Material.Rounded.HourglassEmpty : Icons.Material.Rounded.AccountBalance)">
            @(_checking ? "Prüfe…" : "Kontostand prüfen")
        </MudButton>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(_file is null || _selectedAccountId is null || _uploading)"
                   OnClick="OnUpload"
                   StartIcon="@(_uploading ? Icons.Material.Rounded.HourglassEmpty : Icons.Material.Rounded.Upload)">
            @(_uploading ? "Wird hochgeladen..." : "Hochladen")
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    private IBrowserFile? _file;
    private Guid? _selectedAccountId;
    private List<Contracts.Accounts.Account>? _accounts;
    private bool _uploading;
    private bool _checking;
    private AccountBalanceCheck? _balanceCheck;

    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Import", "/import", icon: Icons.Material.Rounded.FileUpload)
    ];

    private Severity BalanceSeverity =>
        _balanceCheck switch
        {
            null => Severity.Info,
            { LatestStatementDate: null } => Severity.Info,
            { Difference: 0m } => Severity.Success,
            _ => Severity.Warning,
        };

    protected override async Task OnInitializedAsync()
    {
        var accounts = await Api.GetAccountsAsync(AccountType.Asset);
        _accounts = accounts?.ToList() ?? [];
    }

    private async Task OnUpload()
    {
        if (_file is null || _selectedAccountId is null || PeriodState.SelectedPeriodId is null) return;

        _uploading = true;
        try
        {
            var result = await UploadAsync(ignoreBalanceMismatch: false);
            if (result.Success)
            {
                Snackbar.Add("Datei erfolgreich hochgeladen!", Severity.Success);
                _file = null;
                return;
            }

            var confirmed = await ConfirmMismatchAsync(result.Mismatches);
            if (!confirmed) return;

            var forced = await UploadAsync(ignoreBalanceMismatch: true);
            if (forced.Success)
            {
                Snackbar.Add("Datei trotz Abweichung importiert.", Severity.Warning);
                _file = null;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task OnCheckBalance()
    {
        if (_selectedAccountId is null || PeriodState.SelectedPeriodId is null) return;

        _checking = true;
        _balanceCheck = null;
        try
        {
            _balanceCheck = await Api.GetAccountBalanceCheckAsync(
                PeriodState.SelectedPeriodId.Value,
                _selectedAccountId.Value);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Prüfen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _checking = false;
        }
    }

    private async Task<KaesseliApiService.UploadFileResult> UploadAsync(bool ignoreBalanceMismatch)
    {
        await using var stream = _file!.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        return await Api.UploadFileAsync(
            stream,
            _file.Name,
            _selectedAccountId!.Value,
            PeriodState.SelectedPeriodId!.Value,
            ignoreBalanceMismatch);
    }

    private async Task<bool> ConfirmMismatchAsync(IReadOnlyList<Contracts.Integration.BalanceMismatch> mismatches)
    {
        var parameters = new DialogParameters
        {
            { nameof(BalanceMismatchDialog.Mismatches), mismatches }
        };

        var dialog = await DialogService.ShowAsync<BalanceMismatchDialog>("Kontostand stimmt nicht", parameters);
        var result = await dialog.Result;
        return result is { Canceled: false, Data: true };
    }
}
