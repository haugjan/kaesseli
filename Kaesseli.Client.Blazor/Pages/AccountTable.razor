@page "/accountTable/{AccountId:guid}"
@using Kaesseli.Client.Blazor.Components
@using Kaesseli.Client.Blazor.Services
@inject KaesseliApiService Api
@inject AccountingPeriodState PeriodState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>@(_account?.Name ?? "Konto")</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-4" />

@if (_account is null)
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" />
}
else
{
    <MudCard Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
        <MudCardHeader>
            <CardHeaderAvatar>
                <MudAvatar Style="@($"background-color: {_account.IconColor}; color: white;")" Size="Size.Medium">
                    <MudIcon Icon="@GetMudIcon(_account.Icon)" />
                </MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@_account.Name (@_account.Type)</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Class="pt-0">
            <div class="d-flex flex-wrap gap-2 mb-4">
                <MudChip T="string" Color="Color.Primary" Icon="@Icons.Material.Rounded.AccountBalanceWallet">
                    @FormatNumber(_account.AccountBalance)
                </MudChip>
                @if (_account.TypeId is AccountType.Revenue or AccountType.Expense)
                {
                    <MudChip T="string" Style="background-color: #795548; color: white;" Icon="@Icons.Material.Rounded.Savings">
                        Σ @FormatNullable(_account.Budget)
                    </MudChip>
                    <MudChip T="string" Style="background-color: #795548; color: white;" Icon="@Icons.Material.Rounded.Savings">
                        p.M. @FormatNullable(_account.BudgetPerMonth)
                    </MudChip>
                    <MudChip T="string" Style="background-color: #795548; color: white;" Icon="@Icons.Material.Rounded.Savings">
                        p.J. @FormatNullable(_account.BudgetPerYear)
                    </MudChip>
                    <MudChip T="string" Style="background-color: #A1887F; color: white;" Icon="@Icons.Material.Rounded.Savings">
                        Aktuell @FormatNullable(_account.CurrentBudget)
                    </MudChip>
                    @if (_account.BudgetBalance.HasValue)
                    {
                        <MudChip T="string"
                                 Style="@(_account.BudgetBalance.Value >= 0 ? "background-color: #21BA45; color: white;" : "background-color: #C10015; color: white;")"
                                 Icon="@Icons.Material.Rounded.Balance">
                            @FormatNumber(_account.BudgetBalance.Value)
                        </MudChip>
                    }
                }
            </div>

            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudTable Items="_account.Entries" Dense="true" Hover="true" Elevation="0"
                          Style="background: transparent;" Breakpoint="Breakpoint.None">
                    <HeaderContent>
                        <MudTh>Datum</MudTh>
                        <MudTh>Beschreibung</MudTh>
                        <MudTh>Gegenkonto</MudTh>
                        <MudTh Style="text-align: right;">Betrag</MudTh>
                        <MudTh Style="width: 48px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="@RowStyle(context)">@context.ValueDate.ToString("dd.MM.yyyy")</MudTd>
                        <MudTd Style="@RowStyle(context)">@context.Description</MudTd>
                        <MudTd Style="@RowStyle(context)">@context.OtherAccount</MudTd>
                        <MudTd Style="@AmountStyle(context)">@FormatNumber(context.Amount)</MudTd>
                        <MudTd Style="text-align: right;">
                            @if (IsDeletable(context))
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                               Size="Size.Small"
                                               Color="Color.Default"
                                               OnClick="@(() => ConfirmDeleteAsync(context))" />
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <div class="entry-mobile-list">
                    @foreach (var entry in _account.Entries)
                    {
                        var e = entry;
                        <div class="entry-mobile-row" style="@RowStyle(e)">
                            <span class="entry-mobile-date">@e.ValueDate.ToString("dd.MM.yyyy")</span>
                            <span class="entry-mobile-other">@e.OtherAccount</span>
                            <span class="entry-mobile-amount" style="@AmountStyle(e)">@FormatNumber(e.Amount)</span>
                            <span class="entry-mobile-description">@e.Description</span>
                            @if (IsDeletable(e))
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                               Size="Size.Small"
                                               Color="Color.Default"
                                               Class="entry-mobile-delete"
                                               OnClick="@(() => ConfirmDeleteAsync(e))" />
                            }
                        </div>
                    }
                </div>
            </MudHidden>
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter] public Guid AccountId { get; set; }

    private AccountStatement? _account;

    private List<BreadcrumbItem> _breadcrumbs =>
    [
        new("Kontoübersicht", "/accounts", icon: Icons.Material.Rounded.AccountBalance),
        new(_account?.Name ?? "...", null, disabled: true),
    ];

    protected override async Task OnInitializedAsync()
    {
        PeriodState.OnChange += OnPeriodChanged;
        await LoadAsync();
    }

    private void OnPeriodChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _account = null;
            await LoadAsync();
            StateHasChanged();
        });
    }

    private async Task LoadAsync()
    {
        if (PeriodState.SelectedPeriodId is null) return;
        _account = await Api.GetAccountStatementAsync(PeriodState.SelectedPeriodId.Value, AccountId);
    }

    private static bool IsDeletable(AccountStatementEntry entry) =>
        entry.AmountType is AmountType.Credit or AmountType.Debit;

    private async Task ConfirmDeleteAsync(AccountStatementEntry entry)
    {
        var parameters = new DialogParameters
        {
            { nameof(DeleteJournalEntryConfirmationDialog.Amount), entry.Amount },
            { nameof(DeleteJournalEntryConfirmationDialog.Description), entry.Description },
            { nameof(DeleteJournalEntryConfirmationDialog.ValueDate), entry.ValueDate },
        };

        var dialog = await DialogService.ShowAsync<DeleteJournalEntryConfirmationDialog>("Buchung löschen", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        try
        {
            await Api.DeleteJournalEntryAsync(entry.Id);
            Snackbar.Add("Buchung gelöscht.", Severity.Success);
            await LoadAsync();
        }
        catch
        {
            Snackbar.Add("Fehler beim Löschen.", Severity.Error);
        }
    }

    private static string FormatNumber(decimal value) => value.ToString("N2");

    private static string FormatNullable(decimal? value) => value.HasValue ? value.Value.ToString("N2") : "";

    private static string RowStyle(AccountStatementEntry entry) => entry.AmountType switch
    {
        AmountType.Budget => "font-style: italic;",
        AmountType.OpeningBalance => "background-color: rgba(33, 150, 243, 0.08); font-weight: 600;",
        _ => ""
    };

    private static string AmountStyle(AccountStatementEntry entry)
    {
        var baseStyle = entry.AmountType switch
        {
            AmountType.Budget => "font-style: italic; ",
            AmountType.OpeningBalance => "background-color: rgba(33, 150, 243, 0.08); font-weight: 600; ",
            _ => ""
        };
        var color = entry.Amount >= 0 ? "color: #21BA45;" : "color: #C10015;";
        return $"{baseStyle}text-align: right; font-weight: 700; {color}";
    }

    private static string GetMudIcon(string iconName) =>
        Components.AccountDialog.ResolveIcon(iconName);

    public void Dispose() => PeriodState.OnChange -= OnPeriodChanged;
}
