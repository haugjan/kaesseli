@page "/accounts"
@using Kaesseli.Client.Blazor.Services
@inject KaesseliApiService Api
@inject AccountingPeriodState PeriodState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Kontoübersicht</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-4" />

@if (_accounts is null)
{
    @foreach (var _ in _accountTypes)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="mb-4" />
    }
}
else
{
    @foreach (var type in _accountTypes)
    {
        var typeAccounts = _accounts.Where(a => a.Type == type.Name).OrderBy(a => a.Number).ToList();
        if (typeAccounts.Count == 0) continue;

        <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Style="@($"background-color: {type.Color}; color: white;")" Size="Size.Medium">
                        <MudIcon Icon="@type.Icon" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@type.Name</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudTable Items="typeAccounts" Dense="true" Hover="true" Elevation="0"
                              OnRowClick="OnRowClick" T="AccountOverview" Style="background: transparent;"
                              Breakpoint="Breakpoint.None">
                        <HeaderContent>
                            <MudTh Style="width: 48px;"></MudTh>
                            <MudTh>Nr.</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh Style="text-align: right;">Kontostand</MudTh>
                            @if (type.ShowBudget)
                            {
                                <MudTh Style="text-align: right;">Budget p.M.</MudTh>
                                <MudTh Style="text-align: right;">Budget aktuell</MudTh>
                                <MudTh Style="text-align: right;">Budgetsaldo</MudTh>
                            }
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudAvatar Size="Size.Small" Style="@($"background-color: {context.IconColor}; color: white;")">
                                    <MudIcon Icon="@GetMudIcon(context.Icon)" Size="Size.Small" />
                                </MudAvatar>
                            </MudTd>
                            <MudTd>@context.Number</MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd Style="text-align: right;">@FormatNumber(context.AccountBalance)</MudTd>
                            @if (type.ShowBudget)
                            {
                                <MudTd Style="text-align: right;">@FormatNullable(context.BudgetPerMonth)</MudTd>
                                <MudTd Style="text-align: right;">@FormatNullable(context.CurrentBudget)</MudTd>
                                <MudTd Style="@BudgetBalanceStyle(context.BudgetBalance)">@FormatNullable(context.BudgetBalance)</MudTd>
                            }
                        </RowTemplate>
                    </MudTable>
                </MudHidden>
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <div class="account-mobile-list">
                        @foreach (var account in typeAccounts)
                        {
                            var acc = account;
                            <div class="account-mobile-row" @onclick="@(() => Navigation.NavigateTo($"/accountTable/{acc.Id}"))">
                                <div class="account-mobile-icon">
                                    <MudAvatar Size="Size.Small" Style="@($"background-color: {acc.IconColor}; color: white;")">
                                        <MudIcon Icon="@GetMudIcon(acc.Icon)" Size="Size.Small" />
                                    </MudAvatar>
                                </div>
                                <div class="account-mobile-main">
                                    <span class="account-mobile-name">@acc.Name</span>
                                    <span class="account-mobile-account-number">@acc.Number</span>
                                </div>
                                <div class="account-mobile-numbers">
                                    <span class="account-mobile-number">@FormatNumber(acc.AccountBalance)</span>
                                    @if (type.ShowBudget)
                                    {
                                        <span class="account-mobile-number account-mobile-number-secondary">@FormatNullable(acc.BudgetPerMonth)</span>
                                        <span class="account-mobile-number" style="@BudgetBalanceStyle(acc.BudgetBalance)">@FormatNullable(acc.BudgetBalance)</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </MudHidden>
            </MudCardContent>
        </MudCard>
    }
}

@code {
    private List<AccountOverview>? _accounts;

    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Kontoübersicht", "/accounts", icon: Icons.Material.Rounded.AccountBalance)
    ];

    private static readonly AccountTypeInfo[] _accountTypes =
    [
        new("Einkommen", Icons.Material.Rounded.AttachMoney, "#21BA45", true),
        new("Ausgaben", Icons.Material.Rounded.MoneyOff, "#C10015", true),
        new("Aktiv", Icons.Material.Rounded.AccountBalance, "#1976D2", false),
        new("Passiv", Icons.Material.Rounded.AccountBalanceWallet, "#795548", false),
    ];

    protected override async Task OnInitializedAsync()
    {
        PeriodState.OnChange += OnPeriodChanged;
        await LoadAsync();
    }

    private void OnPeriodChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _accounts = null;
            await LoadAsync();
            StateHasChanged();
        });
    }

    private async Task LoadAsync()
    {
        if (PeriodState.SelectedPeriodId is null) return;
        var result = await Api.GetAccountSummariesAsync(PeriodState.SelectedPeriodId.Value);
        _accounts = result?.ToList() ?? [];
    }

    private void OnRowClick(TableRowClickEventArgs<AccountOverview> args)
    {
        Navigation.NavigateTo($"/accountTable/{args.Item!.Id}");
    }

    private static string FormatNumber(decimal value) =>
        value.ToString("N2");

    private static string FormatNullable(decimal? value) =>
        value.HasValue ? value.Value.ToString("N2") : "";

    private static string BudgetBalanceStyle(decimal? value)
    {
        if (!value.HasValue) return "text-align: right;";
        var color = value.Value >= 0 ? "#21BA45" : "#C10015";
        return $"text-align: right; font-weight: 700; color: {color};";
    }

    private static string GetMudIcon(string iconName) =>
        Components.AccountDialog.ResolveIcon(iconName);

    public void Dispose() => PeriodState.OnChange -= OnPeriodChanged;

    private record AccountTypeInfo(string Name, string Icon, string Color, bool ShowBudget);
}
