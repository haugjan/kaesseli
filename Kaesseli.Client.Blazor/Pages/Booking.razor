@page "/booking"
@using Kaesseli.Client.Blazor.Services
@inject KaesseliApiService Api
@inject AccountingPeriodState PeriodState
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Manuelle Buchung</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-4" />

<MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; max-width: 720px;">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar Style="background-color: #1976D2; color: white;" Size="Size.Medium">
                <MudIcon Icon="@Icons.Material.Rounded.EditNote" />
            </MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Manuelle Buchung</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Periode: @(PeriodState.Periods.FirstOrDefault(p => p.Id == PeriodState.SelectedPeriodId)?.Description ?? "—")
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (_accounts is null)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="280px" />
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_date"
                                   Label="Datum"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   DateFormat="dd.MM.yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_amount"
                                     Label="Betrag"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Format="N2"
                                     HideSpinButtons="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_description"
                                  Label="Text"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudAutocomplete T="Contracts.Accounts.Account"
                                     @bind-Value="_debitAccount"
                                     Label="Soll"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     SearchFunc="SearchAccounts"
                                     ToStringFunc="@(a => FormatSelected(a, isDebit: true))"
                                     OpenOnFocus="true"
                                     ResetValueOnEmptyText="true"
                                     Clearable="true"
                                     CoerceText="true"
                                     MaxItems="500"
                                     AnchorOrigin="Origin.BottomLeft">
                        <ItemTemplate Context="account">
                            @{ var inc = IsIncreasing(account.TypeId, isDebit: true); }
                            <span style="@($"color: {(inc ? "#21BA45" : "#C10015")}; font-weight: 700; margin-right: 6px;")">@(inc ? "↑" : "↓")</span>
                            @account.Number @account.Name
                        </ItemTemplate>
                    </MudAutocomplete>
                    @{ var debit = GetEffect(_debitAccount, isDebit: true); }
                    @if (debit is not null)
                    {
                        <div class="booking-effect">
                            <span>Saldo @(debit.Increases ? "wird erhöht" : "wird verringert") (@debit.TypeLabel)</span>
                        </div>
                    }
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudAutocomplete T="Contracts.Accounts.Account"
                                     @bind-Value="_creditAccount"
                                     Label="Haben"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     SearchFunc="SearchAccounts"
                                     ToStringFunc="@(a => FormatSelected(a, isDebit: false))"
                                     OpenOnFocus="true"
                                     ResetValueOnEmptyText="true"
                                     Clearable="true"
                                     CoerceText="true"
                                     MaxItems="500"
                                     AnchorOrigin="Origin.BottomLeft">
                        <ItemTemplate Context="account">
                            @{ var inc = IsIncreasing(account.TypeId, isDebit: false); }
                            <span style="@($"color: {(inc ? "#21BA45" : "#C10015")}; font-weight: 700; margin-right: 6px;")">@(inc ? "↑" : "↓")</span>
                            @account.Number @account.Name
                        </ItemTemplate>
                    </MudAutocomplete>
                    @{ var credit = GetEffect(_creditAccount, isDebit: false); }
                    @if (credit is not null)
                    {
                        <div class="booking-effect">
                            <span>Saldo @(credit.Increases ? "wird erhöht" : "wird verringert") (@credit.TypeLabel)</span>
                        </div>
                    }
                </MudItem>
            </MudGrid>
        }
    </MudCardContent>
    <MudCardActions>
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Save"
                   Disabled="@(!CanSave || _saving)"
                   OnClick="SaveAsync">
            @(_saving ? "Speichert…" : "Speichern")
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    private List<Contracts.Accounts.Account>? _accounts;
    private DateTime? _date = DateTime.Today;
    private string? _description;
    private decimal? _amount;
    private Contracts.Accounts.Account? _debitAccount;
    private Contracts.Accounts.Account? _creditAccount;
    private bool _saving;

    private static readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Manuelle Buchung", "/booking", icon: Icons.Material.Rounded.EditNote)
    ];

    private bool CanSave =>
        PeriodState.SelectedPeriodId.HasValue
        && _date.HasValue
        && _amount is > 0
        && _debitAccount is not null
        && _creditAccount is not null
        && _debitAccount.Id != _creditAccount.Id
        && !string.IsNullOrWhiteSpace(_description);

    private BookingEffect? GetEffect(Contracts.Accounts.Account? account, bool isDebit)
    {
        if (account is null) return null;
        return new BookingEffect(IsIncreasing(account.TypeId, isDebit), FormatType(account.TypeId));
    }

    // Aktiv- und Aufwandskonten erhöhen sich im Soll, Passiv- und Ertragskonten im Haben.
    private static bool IsIncreasing(AccountType type, bool isDebit)
    {
        var increasesOnDebit = type is AccountType.Asset or AccountType.Expense;
        return isDebit ? increasesOnDebit : !increasesOnDebit;
    }

    private static string FormatSelected(Contracts.Accounts.Account? account, bool isDebit)
    {
        if (account is null) return string.Empty;
        var arrow = IsIncreasing(account.TypeId, isDebit) ? "↑" : "↓";
        return $"{arrow}  {account.Number} {account.Name}";
    }

    private static string FormatType(AccountType type) => type switch
    {
        AccountType.Asset => "Aktiv",
        AccountType.Liability => "Passiv",
        AccountType.Revenue => "Einkommen",
        AccountType.Expense => "Ausgabe",
        _ => type.ToString()
    };

    private Task<IEnumerable<Contracts.Accounts.Account>> SearchAccounts(string? value, CancellationToken _)
    {
        IEnumerable<Contracts.Accounts.Account> source = _accounts ?? [];
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(source);
        }

        // Wenn der aktuelle Text dem aktuell gewählten Konto (mit Pfeil-Präfix) entspricht,
        // beim erneuten Öffnen die volle Liste zeigen statt nur den einen Treffer.
        if (source.Any(a =>
                string.Equals(FormatSelected(a, isDebit: true), value, StringComparison.OrdinalIgnoreCase)
                || string.Equals(FormatSelected(a, isDebit: false), value, StringComparison.OrdinalIgnoreCase)))
        {
            return Task.FromResult(source);
        }

        var query = value.Trim();
        return Task.FromResult(source.Where(a => MatchesWordStart(a, query)));
    }

    private static bool MatchesWordStart(Contracts.Accounts.Account account, string query)
    {
        if (account.Number.StartsWith(query, StringComparison.OrdinalIgnoreCase)
            || account.ShortName.StartsWith(query, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        foreach (var word in account.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries))
        {
            if (word.StartsWith(query, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }
        return false;
    }

    private sealed record BookingEffect(bool Increases, string TypeLabel);

    protected override async Task OnInitializedAsync()
    {
        PeriodState.OnChange += OnPeriodChanged;
        await LoadAccountsAsync();
    }

    private async Task LoadAccountsAsync()
    {
        var result = await Api.GetAccountsAsync();
        _accounts = result?.OrderBy(a => a.Number).ToList() ?? [];
    }

    private void OnPeriodChanged() => InvokeAsync(StateHasChanged);

    private async Task SaveAsync()
    {
        if (!CanSave || _saving) return;
        _saving = true;
        try
        {
            await Api.AddJournalEntryAsync(
                _amount!.Value,
                _description!,
                DateOnly.FromDateTime(_date!.Value),
                _debitAccount!.Id,
                _creditAccount!.Id,
                PeriodState.SelectedPeriodId!.Value);

            Snackbar.Add("Buchung gespeichert.", Severity.Success);

            // Form zurücksetzen — Datum und Text bleiben für Folgebuchungen erhalten.
            _amount = null;
            _debitAccount = null;
            _creditAccount = null;
        }
        catch
        {
            Snackbar.Add("Fehler beim Speichern.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose() => PeriodState.OnChange -= OnPeriodChanged;
}
