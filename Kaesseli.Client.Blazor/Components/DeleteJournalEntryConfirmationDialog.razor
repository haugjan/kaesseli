<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-2">
            Buchung <b>@Description</b> vom @ValueDate.ToString("dd.MM.yyyy") über <b>@Amount.ToString("N2")</b> wird unwiderruflich gelöscht.
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Nein</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Submit">
            Ja, löschen
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired] public decimal Amount { get; set; }
    [Parameter, EditorRequired] public string Description { get; set; } = "";
    [Parameter, EditorRequired] public DateOnly ValueDate { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();
}
