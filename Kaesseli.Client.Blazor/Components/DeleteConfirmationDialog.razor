<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            <b>@EntityDescription</b> wird unwiderruflich gelöscht.
        </MudAlert>
        <MudText Class="mb-2">
            Zur Bestätigung bitte den Namen <b>@ConfirmText</b> exakt eingeben:
        </MudText>
        <MudTextField @bind-Value="_input" Label="Name" Immediate="true" Error="@(_input.Length > 0 && !IsMatch)"
                      ErrorText="Eingabe stimmt nicht überein" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" Disabled="@(!IsMatch)" OnClick="Submit">
            Löschen
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired] public string EntityDescription { get; set; } = "";
    [Parameter, EditorRequired] public string ConfirmText { get; set; } = "";

    private string _input = "";

    private bool IsMatch => string.Equals(_input.Trim(), ConfirmText, StringComparison.Ordinal);

    private void Submit()
    {
        if (IsMatch) MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
