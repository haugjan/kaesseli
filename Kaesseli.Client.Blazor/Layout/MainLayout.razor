@inherits LayoutComponentBase
@using Kaesseli.Client.Blazor.Theme
@using Kaesseli.Client.Blazor.Services
@inject KaesseliApiService Api
@inject AccountingPeriodState PeriodState
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Style="border-bottom: 1px solid var(--mud-palette-divider);">
        <MudIconButton Icon="@Icons.Material.Rounded.Menu" Color="Color.Dark" Edge="Edge.Start"
                       OnClick="@(_ => _drawerOpen = !_drawerOpen)" />
        <MudSpacer />
        @if (PeriodState.Periods.Any())
        {
            <MudSelect T="Guid" Value="PeriodState.SelectedPeriodId!.Value"
                       ValueChanged="OnPeriodChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="min-width: 180px; margin-right: 8px;"
                       AnchorOrigin="Origin.BottomLeft">
                @foreach (var period in PeriodState.Periods)
                {
                    <MudSelectItem Value="period.Id">@period.Description</MudSelectItem>
                }
            </MudSelect>
        }
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)"
                       Color="Color.Dark"
                       OnClick="@(_ => _isDarkMode = !_isDarkMode)" />
        <LoginDisplay />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Never">
        <div class="drawer-header">
            <MudIcon Icon="@Icons.Material.Rounded.Savings" Style="color: #76B041;" Size="Size.Medium" />
            <MudText Style="font-weight: 700; font-size: 1.1rem; color: #FFFFFF; letter-spacing: -0.2px;">Käseli</MudText>
        </div>
        <MudDivider Style="border-color: rgba(255,255,255,0.08);" />
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    readonly MudTheme _theme = KaesseliTheme.Create();
    bool _isDarkMode;
    bool _drawerOpen = true;

    protected override async Task OnInitializedAsync()
    {
        var periods = (await Api.GetAccountingPeriodsAsync())?.ToList() ?? [];
        var savedId = await JS.InvokeAsync<string?>("localStorage.getItem", "selectedPeriod");
        var parsed = Guid.TryParse(savedId, out var id) ? id : (Guid?)null;
        PeriodState.Initialize(periods, parsed);
    }

    async Task OnPeriodChanged(Guid id)
    {
        PeriodState.SelectPeriod(id);
        await JS.InvokeVoidAsync("localStorage.setItem", "selectedPeriod", id.ToString());
    }
}
